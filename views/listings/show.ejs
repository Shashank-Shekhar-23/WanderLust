<% layout("./layouts/basic.ejs") %>

    <body>
        <div class="row">
            <div class="col-md-8 offset-2 show-card">
                <h3>
                    <%= listing.title %>
                </h3>
                <img src="<%= listing.image.url %>" alt="listing_img" class="listing-img">
                <p class="show-des">
                    <%= listing.description %>
                </p>
                <p>Price: &#8377; <%= listing.price.toLocaleString("en-IN") %>
                        <p>
                        <p>location: <%= listing.location %>
                        </p>
                        <p>Country: <%= listing.country %>
                        </p>
                        <div class="show-btns">
                            <a href="/listings/<%= listing._id %>/edit" class="btn btn-bg-dark edit-btn">Edit</a>
                            <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
                                <button class="btn btn-bg-dark edit-btn">Delete</button>
                            </form>
                        </div>
            </div>
        </div>

        <!-- <ul>
            <li>
                <%= listing.description %>
            </li>
            <li>&#8377; <%= listing.price.toLocaleString("en-IN") %>
            </li>
            <li>
                <%= listing.location %>
            </li>
            <li>
                <%= listing.country %>
            </li>
            <li><a href="/listings/<%= listing._id %>/edit">Edit</a></li>
        </ul>
        <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
            <button>Delete</button>
        </form> -->


        <div class="col-8 offset-2 mb-3">
            <hr>
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label>
                    <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range" />
                </div>
                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comments</label>
                    <textarea name="review[comment]" id="comment" cols="20" rows="3" class="form-control"
                        required></textarea>
                    <div class="invalid-feedback">Please add some comments for review</div>
                </div>

                <button class="btn btn-outline-dark">Submit</button>
            </form>

            <hr>

            <h4>All Reviews</h4>
            <div class="row">
                <% for(review of listing.reviews) { %>
                    <div class="card col-5 mb-2 ms-2">
                        <div class="card-body">
                            <h5 class="card-title">Title</h5>
                            <p class="card-text">
                                <%= review.comment %>
                            </p>
                            <p class="card-text">
                                <%= review.rating %> stars
                            </p>
                            <form class="mb-3" method="POST"
                                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                <button class="btn btn-dark btn-sm">Delete</button>
                            </form>
                        </div>
                    </div>
                    <% } %>
            </div>

        </div>

    </body>